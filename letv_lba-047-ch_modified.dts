#include "qca953x.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

/ {
    compatible = "letv,lba-047-ch", "qca,qca9533";
    model = "Letv LBA-047-CH";

    aliases {
        led-boot = &led_blue;
        led-failsafe = &led_blue;
        led-running = &led_blue;
        led-upgrade = &led_red;
    };

    keys {
        compatible = "gpio-keys";

        reset {
            label = "reset";
            linux,code = <KEY_RESTART>;
            gpios = <&gpio 17 GPIO_ACTIVE_LOW>;
            debounce-interval = <60>;
        };
    };

    leds {
        compatible = "gpio-leds";

        led_red: red {
            label = "red:status";
            gpios = <&gpio 11 GPIO_ACTIVE_LOW>;
        };

        led_blue: blue {
            label = "blue:status";
            gpios = <&gpio 13 GPIO_ACTIVE_LOW>;
        };
    };
};

&spi {
    status = "okay";

    flash@0 {
        compatible = "jedec,spi-nor";
        reg = <0>;
        spi-max-frequency = <25000000>;

        partitions {
            compatible = "fixed-partitions";
            #address-cells = <1>;
            #size-cells = <1>;

            partition@0 {
                label = "u-boot";
                reg = <0x000000 0x040000>;
                read-only;
            };

            partition@40000 {
                label = "u-boot-env";
                reg = <0x040000 0x010000>;
            };

            partition@50000 {
                label = "fwconcat0";
                reg = <0x050000 0xe30000>;
            };

            partition@e80000 {
                label = "loader";
                reg = <0xe80000 0x010000>;
            };

            partition@e90000 {
                label = "fwconcat1";
                reg = <0xe90000 0x160000>;
            };

            art: partition@ff0000 {
                label = "art";
                reg = <0xff0000 0x010000>;
                read-only;
            };
        };
    };
};

&eth0 {
    status = "okay";

    phy-handle = <&swphy4>;
};

&eth1 {
    status = "okay";
};

&mdio0 {
    status = "okay";

    swphy4: ethernet-phy@4 {
        reg = <4>;
    };
};

// ===== 新增：启用 USB 控制器 =====
&usb0 {
    status = "okay";
};

&usb1 {
    status = "okay";
};

// ===== 新增：启用 PCIe 控制器 =====
&pcie0 {
    status = "okay";
    // PERST# GPIO 12 (根据用户反馈)
    reset-gpios = <&gpio 12 GPIO_ACTIVE_LOW>;
};

// ===== 新增：启用 GPIO =====
&gpio {
    status = "okay";
};

&wmac {
    status = "okay";

    mtd-cal-data = <&art 0x1002>;
};
